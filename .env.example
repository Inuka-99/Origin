# =============================================================================
# ORIGIN Frontend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your Auth0 values.
# Vite exposes variables prefixed with VITE_ to the browser.
# NEVER put secrets here — everything below is public.
# =============================================================================

# Auth0 tenant domain (e.g. dev-abc123.us.auth0.com)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com

# Auth0 SPA Application Client ID
VITE_AUTH0_CLIENT_ID=your-client-id

# Auth0 API audience identifier
VITE_AUTH0_AUDIENCE=https://api.originapp.com

# Backend API base URL
VITE_API_URL=http://localhost:3000

# Supabase — public/anon key (safe to expose in frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
