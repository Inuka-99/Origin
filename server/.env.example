# =============================================================================
# ORIGIN Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your Auth0 values.
# These values come from the Auth0 Dashboard → APIs → Your API.
# =============================================================================

# Port the NestJS server listens on
PORT=3000

# Auth0 tenant domain (must match the frontend value)
AUTH0_DOMAIN=your-tenant.us.auth0.com

# Auth0 API audience identifier (must match the frontend value)
AUTH0_AUDIENCE=https://api.originapp.com

# Issuer URL — Auth0 always uses https://{domain}/
AUTH0_ISSUER_URL=https://your-tenant.us.auth0.com/

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173
