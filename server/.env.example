# =============================================================================
# ORIGIN Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your Auth0 values.
# These values come from the Auth0 Dashboard → APIs → Your API.
# =============================================================================

# Port the NestJS server listens on
PORT=3000

# Auth0 tenant domain (must match the frontend value)
AUTH0_DOMAIN=your-tenant.us.auth0.com

# Auth0 API audience identifier (must match the frontend value)
AUTH0_AUDIENCE=https://api.originapp.com

# Issuer URL — Auth0 always uses https://{domain}/
AUTH0_ISSUER_URL=https://your-tenant.us.auth0.com/

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173

# Supabase — get these from Project Settings → API in your Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# Google Calendar integration
# =============================================================================
# Public base URL of this backend. Used to build the OAuth redirect_uri and
# absolute links in event descriptions. Dev: http://localhost:3000
BACKEND_URL=http://localhost:3000

# OAuth 2.0 Web Client (GCP Console → APIs & Services → Credentials)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/oauth/callback

# Default calendar to write to (users can override per-connection)
GOOGLE_CALENDAR_DEFAULT_ID=primary

# AES-256-GCM key (32 bytes, base64-encoded) used to encrypt stored refresh /
# access tokens at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GCAL_TOKEN_ENC_KEY=

# Random secret used to sign the OAuth `state` JWT (HS256). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GCAL_OAUTH_STATE_SECRET=

# =============================================================================
# Auth0 Management API (used to read the federated Google refresh token
# for users who signed up with "Continue with Google")
# =============================================================================
# Create a Machine-to-Machine app authorized for the Management API with
# scopes: read:users, read:user_idp_tokens
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=
# Leave the default — derived at runtime from AUTH0_DOMAIN if empty
AUTH0_MGMT_AUDIENCE=
